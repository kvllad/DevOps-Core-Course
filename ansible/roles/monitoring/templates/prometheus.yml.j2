global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_scrape_interval }}

scrape_configs:
{% for target in prometheus_targets %}
  - job_name: '{{ target.job }}'
    static_configs:
      - targets:
{% for item in target.targets %}
          - {{ item }}
{% endfor %}
{% if target.path is defined %}
    metrics_path: '{{ target.path }}'
{% endif %}

{% endfor %}
